{
  "name": "@fidely-ui/panda-preset",
  "version": "2.1.0",
  "description": "Fidely UI Panda CSS Preset",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./colors/*": {
      "types": "./dist/colors/*.d.ts",
      "import": "./dist/colors/*.js",
      "require": "./dist/colors/*.cjs"
    },
    "./anatomy": {
      "types": "./dist/anatomy/index.d.ts",
      "import": "./dist/anatomy/index.js",
      "require": "./dist/anatomy/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "preprepare": "pnpm -F @fidely-ui/panda-preset build",
    "clean": "rimraf --no-glob ./dist",
    "build": "pnpm clean && tsup --config tsup.config.ts && tsc --outDir dist --project tsconfig.json",
    "prebuild": "pnpm clean",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx --config ../../eslint.config.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fidely-ui/fidely-ui",
    "directory": "packages/presets"
  },
  "bugs": {
    "url": "https://github.com/fidely-ui/fidely-ui/issues"
  },
  "homepage": "https://fidely-ui.vercel.app/",
  "keywords": [
    "Fidely UI",
    "presets",
    "fidely preset",
    "panda css",
    "fidely-ui"
  ],
  "author": "Justice Chimobi <chimobi.justice@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.30.0",
  "peerDependencies": {
    "@pandacss/dev": ">=1.1.0"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.8.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
